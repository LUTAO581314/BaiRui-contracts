{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/approval.schema.json",
  "title": "Approval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "organization_id",
    "user_id",
    "agent_id",
    "server_id",
    "request_id",
    "correlation_id",
    "idempotency_key",
    "created_at",
    "revision",
    "sequence",
    "signature",
    "approval_id",
    "command_id",
    "action",
    "risk_level",
    "requested_by",
    "decision",
    "expires_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "user_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "server_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value",
        "signed_at"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "ed25519",
            "hmac-sha256"
          ]
        },
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/=_-]{16,2048}$"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "approval_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "command_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "action": {
      "enum": [
        "snapshot.collect",
        "deployment.provision",
        "deployment.start",
        "deployment.stop",
        "deployment.suspend",
        "deployment.resume",
        "deployment.delete",
        "credential.revoke",
        "probe.run",
        "contract.test",
        "smoke.test",
        "upstream.check",
        "config.stage",
        "config.apply",
        "config.apply-user",
        "backup.create",
        "backup.verify",
        "backup.restore",
        "backup.expire",
        "release.stage",
        "release.apply",
        "release.rollback",
        "service.restart"
      ]
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "requested_by": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "decided_by": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "decision": {
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "reason_code": {
      "enum": [
        "operator_requested",
        "policy_required",
        "break_glass",
        "rollback",
        "recovery",
        "maintenance"
      ]
    },
    "reason_ref": {
      "type": "string",
      "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deployment_id",
        "agent_id",
        "server_id"
      ],
      "properties": {
        "deployment_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "server_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "approved",
              "rejected"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "required": [
          "decided_by",
          "decided_at"
        ],
        "properties": {
          "decided_by": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "decided_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "pending"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "decided_by"
              ],
              "properties": {
                "decided_by": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
                }
              }
            },
            {
              "required": [
                "decided_at"
              ],
              "properties": {
                "decided_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          ]
        }
      }
    }
  ]
}
