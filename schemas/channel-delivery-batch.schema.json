{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v1/channel-delivery-batch.schema.json",
  "title": "ChannelDeliveryBatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lease_id",
    "worker_id",
    "deliveries",
    "leased_until",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "lease_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "worker_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "deliveries": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "outbound_id",
          "binding_id",
          "channel",
          "channel_account_id",
          "conversation",
          "content",
          "attempt",
          "lease_token",
          "available_at",
          "trace"
        ],
        "properties": {
          "outbound_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "binding_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "channel": {
            "enum": [
              "web",
              "cli",
              "feishu",
              "wechat",
              "qq"
            ]
          },
          "channel_account_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "conversation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "channel_conversation_id",
              "kind"
            ],
            "properties": {
              "channel_conversation_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              },
              "kind": {
                "enum": [
                  "direct",
                  "group",
                  "thread"
                ]
              },
              "thread_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              },
              "title": {
                "type": "string",
                "maxLength": 200
              }
            }
          },
          "content": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "text",
                  "markdown",
                  "image",
                  "audio",
                  "file",
                  "event"
                ]
              },
              "text": {
                "type": "string",
                "maxLength": 100000
              },
              "data": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "attachments": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "attachment_id",
                "kind"
              ],
              "properties": {
                "attachment_id": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
                },
                "kind": {
                  "enum": [
                    "image",
                    "audio",
                    "video",
                    "file"
                  ]
                },
                "url": {
                  "type": "string",
                  "format": "uri",
                  "maxLength": 4096
                },
                "media_type": {
                  "type": "string",
                  "maxLength": 200
                },
                "name": {
                  "type": "string",
                  "maxLength": 500
                },
                "size_bytes": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "reply_to_message_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "attempt": {
            "type": "integer",
            "minimum": 1
          },
          "lease_token": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "available_at": {
            "type": "string",
            "format": "date-time"
          },
          "trace": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "correlation_id"
            ],
            "properties": {
              "correlation_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              },
              "parent_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              },
              "span_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              }
            }
          }
        }
      }
    },
    "leased_until": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "parent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "span_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    }
  }
}
