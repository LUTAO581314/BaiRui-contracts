{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/observation.schema.json",
  "title": "Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "organization_id",
    "user_id",
    "agent_id",
    "server_id",
    "request_id",
    "correlation_id",
    "idempotency_key",
    "created_at",
    "revision",
    "sequence",
    "signature",
    "observation_id",
    "deployment_id",
    "observation_version",
    "status",
    "freshness",
    "components",
    "source_identity",
    "redaction_status",
    "observed_at",
    "received_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "user_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "server_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value",
        "signed_at"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "ed25519",
            "hmac-sha256"
          ]
        },
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/=_-]{16,2048}$"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "observation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "deployment_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "observation_version": {
      "type": "integer",
      "minimum": 1
    },
    "desired_state_version": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "enum": [
        "healthy",
        "degraded",
        "unhealthy",
        "unknown"
      ]
    },
    "freshness": {
      "enum": [
        "fresh",
        "stale",
        "invalid"
      ]
    },
    "components": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module_id",
          "status",
          "version",
          "observed_at"
        ],
        "properties": {
          "module_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "status": {
            "enum": [
              "healthy",
              "degraded",
              "unhealthy",
              "unknown"
            ]
          },
          "version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "readiness": {
            "enum": [
              "ready",
              "not_ready",
              "unknown"
            ]
          },
          "image_digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_refs": {
            "type": "array",
            "maxItems": 100,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(?:ref|id|hint|sha256):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            }
          },
          "health_code": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          }
        }
      }
    },
    "source_identity": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "evidence_refs": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:ref|id|hint|sha256):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
      }
    },
    "redaction_status": {
      "const": "redacted"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "freshness_seconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 86400
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
