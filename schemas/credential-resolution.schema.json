{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v1/credential-resolution.schema.json",
  "title": "CredentialResolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authorization",
    "credential"
  ],
  "properties": {
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "service",
        "label",
        "authType",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "service": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "authType": {
          "enum": [
            "api_key",
            "bearer",
            "basic",
            "oauth_refresh"
          ]
        },
        "endpointUrl": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret"
      ],
      "properties": {
        "secret": {
          "type": "string",
          "minLength": 1,
          "maxLength": 65536
        }
      }
    }
  }
}
