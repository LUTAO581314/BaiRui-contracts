{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/credential-resolution.schema.json",
  "title": "CredentialResolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner_scope",
    "authorization",
    "credential"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "owner_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "user_id",
        "agent_id"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "runtime_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      },
      "dependentRequired": {
        "conversation_id": [
          "workspace_id"
        ]
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "service",
        "label",
        "authType",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "service": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "authType": {
          "enum": [
            "api_key",
            "bearer",
            "bearer_token",
            "basic",
            "oauth_refresh"
          ]
        },
        "endpointUrl": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret"
      ],
      "properties": {
        "secret": {
          "type": "string",
          "minLength": 1,
          "maxLength": 65536
        }
      }
    }
  }
}
