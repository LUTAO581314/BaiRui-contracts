{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v1/channel-health-report.schema.json",
  "title": "ChannelHealthReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "channel",
    "worker_id",
    "sequence",
    "status",
    "capabilities",
    "observed_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "binding_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "channel": {
      "enum": [
        "web",
        "cli",
        "feishu",
        "wechat",
        "qq"
      ]
    },
    "worker_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "pending",
        "connected",
        "degraded",
        "error",
        "disconnected",
        "disabled"
      ]
    },
    "capabilities": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "enum": [
          "receive",
          "send",
          "reply",
          "attachments",
          "webhook",
          "websocket"
        ]
      }
    },
    "adapter_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "last_inbound_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_outbound_at": {
      "type": "string",
      "format": "date-time"
    },
    "error_code": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
