{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/desired-state.schema.json",
  "title": "DesiredState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "organization_id",
    "user_id",
    "agent_id",
    "server_id",
    "request_id",
    "correlation_id",
    "idempotency_key",
    "created_at",
    "revision",
    "sequence",
    "signature",
    "deployment_id",
    "version",
    "module_versions",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "user_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "server_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value",
        "signed_at"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "ed25519",
            "hmac-sha256"
          ]
        },
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/=_-]{16,2048}$"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "deployment_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "enum": [
        "provisioned",
        "running",
        "stopped",
        "suspended",
        "deleted"
      ]
    },
    "config_revision_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "module_versions": {
      "type": "object",
      "maxProperties": 100,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$",
            "maxLength": 64
          },
          {
            "type": "string",
            "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          }
        ]
      }
    },
    "modules": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module_id",
          "desired_status",
          "version_ref"
        ],
        "properties": {
          "module_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "desired_status": {
            "enum": [
              "absent",
              "stopped",
              "running",
              "suspended"
            ]
          },
          "version_ref": {
            "type": "string",
            "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "image_digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "config_ref": {
            "type": "string",
            "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
