{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/scene-snapshot.schema.json",
  "title": "SceneSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scene_id",
    "owner_scope",
    "revision",
    "view",
    "generated_at",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "scene_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "owner_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "user_id",
        "agent_id",
        "workspace_id"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "runtime_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      },
      "dependentRequired": {
        "conversation_id": [
          "workspace_id"
        ]
      }
    },
    "revision": {
      "type": "integer",
      "minimum": 0
    },
    "view": {
      "type": "object",
      "additionalProperties": true
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "parent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "span_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    }
  }
}
