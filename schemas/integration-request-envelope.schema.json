{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v1/integration-request-envelope.schema.json",
  "title": "IntegrationRequestEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request"
  ],
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "integration_id",
        "capability",
        "input",
        "timeout_ms",
        "trace"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "integration_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "capability": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        },
        "options": {
          "type": "object",
          "additionalProperties": true
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 900000
        },
        "trace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "correlation_id"
          ],
          "properties": {
            "correlation_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "parent_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "span_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            }
          }
        }
      }
    }
  }
}
