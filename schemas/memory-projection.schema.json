{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/memory-projection.schema.json",
  "title": "MemoryProjection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "projection_id",
    "owner_scope",
    "memory",
    "user",
    "included_note_ids",
    "excluded_note_ids"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "projection_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "owner_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "user_id",
        "agent_id",
        "runtime_id",
        "workspace_id"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "runtime_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      },
      "dependentRequired": {
        "conversation_id": [
          "workspace_id"
        ]
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entries",
        "char_count",
        "limit"
      ],
      "properties": {
        "entries": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "note_id",
              "content"
            ],
            "properties": {
              "note_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              },
              "content": {
                "type": "string",
                "minLength": 1,
                "maxLength": 10000
              }
            }
          }
        },
        "char_count": {
          "type": "integer",
          "minimum": 0
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entries",
        "char_count",
        "limit"
      ],
      "properties": {
        "entries": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "note_id",
              "content"
            ],
            "properties": {
              "note_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
              },
              "content": {
                "type": "string",
                "minLength": 1,
                "maxLength": 10000
              }
            }
          }
        },
        "char_count": {
          "type": "integer",
          "minimum": 0
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "included_note_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
      }
    },
    "excluded_note_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
      }
    }
  }
}
