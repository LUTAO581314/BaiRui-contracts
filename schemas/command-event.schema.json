{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/command-event.schema.json",
  "title": "CommandEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "organization_id",
    "user_id",
    "agent_id",
    "server_id",
    "request_id",
    "correlation_id",
    "idempotency_key",
    "created_at",
    "revision",
    "sequence",
    "signature",
    "event_id",
    "event_sequence",
    "command_id",
    "attempt",
    "state",
    "event_type",
    "occurred_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "user_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "server_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value",
        "signed_at"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "ed25519",
            "hmac-sha256"
          ]
        },
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/=_-]{16,2048}$"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "event_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "event_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "command_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "action": {
      "enum": [
        "snapshot.collect",
        "deployment.provision",
        "deployment.start",
        "deployment.stop",
        "deployment.suspend",
        "deployment.resume",
        "deployment.delete",
        "credential.revoke",
        "probe.run",
        "contract.test",
        "smoke.test",
        "upstream.check",
        "config.stage",
        "config.apply",
        "config.apply-user",
        "backup.create",
        "backup.verify",
        "backup.restore",
        "backup.expire",
        "release.stage",
        "release.apply",
        "release.rollback",
        "service.restart"
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "enum": [
        "queued",
        "leased",
        "accepted",
        "running",
        "executing",
        "verifying",
        "succeeded",
        "failed",
        "cancelled",
        "expired"
      ]
    },
    "event_type": {
      "enum": [
        "command.queued",
        "command.leased",
        "command.accepted",
        "command.started",
        "command.executing",
        "command.progress",
        "command.verifying",
        "command.succeeded",
        "command.failed",
        "command.cancelled",
        "command.expired",
        "lease.renewed"
      ]
    },
    "lease_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "lease_token": {
      "type": "string",
      "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "observation_version": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_refs": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:ref|id|hint|sha256):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
      }
    },
    "error_code": {
      "enum": [
        "invalid_schema_version",
        "unsupported_schema_version",
        "unknown_field",
        "missing_field",
        "invalid_identifier",
        "invalid_action",
        "forbidden_action",
        "forbidden_field",
        "raw_secret_not_allowed",
        "invalid_signature",
        "signature_key_unknown",
        "signature_expired",
        "replay_detected",
        "idempotency_conflict",
        "revision_conflict",
        "sequence_conflict",
        "owner_mismatch",
        "server_mismatch",
        "approval_required",
        "approval_not_valid",
        "lease_not_found",
        "lease_expired",
        "receipt_conflict",
        "release_not_immutable",
        "evidence_not_found"
      ]
    },
    "error_ref": {
      "type": "string",
      "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "message_ref": {
      "type": "string",
      "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "result_ref": {
      "type": "string",
      "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "enum": [
              "succeeded",
              "failed",
              "cancelled",
              "expired"
            ]
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "required": [
          "completed_at"
        ],
        "properties": {
          "completed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "failed"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "required": [
          "error_code"
        ],
        "properties": {
          "error_code": {
            "enum": [
              "invalid_schema_version",
              "unsupported_schema_version",
              "unknown_field",
              "missing_field",
              "invalid_identifier",
              "invalid_action",
              "forbidden_action",
              "forbidden_field",
              "raw_secret_not_allowed",
              "invalid_signature",
              "signature_key_unknown",
              "signature_expired",
              "replay_detected",
              "idempotency_conflict",
              "revision_conflict",
              "sequence_conflict",
              "owner_mismatch",
              "server_mismatch",
              "approval_required",
              "approval_not_valid",
              "lease_not_found",
              "lease_expired",
              "receipt_conflict",
              "release_not_immutable",
              "evidence_not_found"
            ]
          }
        }
      }
    }
  ]
}
