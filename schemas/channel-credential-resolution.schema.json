{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v1/channel-credential-resolution.schema.json",
  "title": "ChannelCredentialResolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "binding",
    "credential"
  ],
  "properties": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "organization_id",
        "user_id",
        "agent_id",
        "channel",
        "channel_account_id",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "channel": {
          "enum": [
            "web",
            "cli",
            "feishu",
            "wechat",
            "qq"
          ]
        },
        "channel_account_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "values"
      ],
      "properties": {
        "values": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 32,
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65536
          }
        }
      }
    }
  }
}
