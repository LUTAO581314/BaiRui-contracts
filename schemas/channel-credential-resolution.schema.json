{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/channel-credential-resolution.schema.json",
  "title": "ChannelCredentialResolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding",
    "credential"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "owner_scope",
        "channel",
        "channel_account_id",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "owner_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "organization_id",
            "user_id",
            "agent_id",
            "workspace_id"
          ],
          "properties": {
            "organization_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "user_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "agent_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "runtime_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "workspace_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            },
            "conversation_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
            }
          },
          "dependentRequired": {
            "conversation_id": [
              "workspace_id"
            ]
          }
        },
        "channel": {
          "enum": [
            "web",
            "cli",
            "feishu",
            "wechat",
            "qq"
          ]
        },
        "channel_account_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "values"
      ],
      "properties": {
        "values": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 32,
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65536
          }
        }
      }
    }
  }
}
