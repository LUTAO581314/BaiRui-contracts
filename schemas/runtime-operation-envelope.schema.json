{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/runtime-operation-envelope.schema.json",
  "title": "RuntimeOperationEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation",
    "owner_scope",
    "actor",
    "input",
    "trace",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "operation": {
      "enum": [
        "health.detailed",
        "discovery.models",
        "discovery.capabilities",
        "discovery.skills",
        "discovery.toolsets",
        "sessions.list",
        "sessions.create",
        "sessions.get",
        "sessions.update",
        "sessions.delete",
        "sessions.messages",
        "sessions.fork",
        "sessions.chat",
        "runs.create",
        "runs.get",
        "runs.approve",
        "runs.stop",
        "jobs.list",
        "jobs.create",
        "jobs.get",
        "jobs.update",
        "jobs.delete",
        "jobs.pause",
        "jobs.resume",
        "jobs.run",
        "memory.snapshot",
        "memory.apply"
      ]
    },
    "owner_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "user_id",
        "agent_id",
        "runtime_id",
        "workspace_id"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "runtime_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      },
      "dependentRequired": {
        "conversation_id": [
          "workspace_id"
        ]
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_id"
      ],
      "properties": {
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "roles": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          }
        }
      }
    },
    "channel_context": {
      "type": "object",
      "additionalProperties": true
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "parent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "span_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
