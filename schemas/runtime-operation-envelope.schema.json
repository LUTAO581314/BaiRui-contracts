{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/runtime-operation-envelope.schema.json",
  "title": "RuntimeOperationEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation",
    "owner_scope",
    "actor",
    "input",
    "trace",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "operation": {
      "enum": [
        "health.detailed",
        "discovery.models",
        "discovery.capabilities",
        "discovery.skills",
        "discovery.toolsets",
        "sessions.list",
        "sessions.create",
        "sessions.get",
        "sessions.update",
        "sessions.delete",
        "sessions.messages",
        "sessions.fork",
        "sessions.chat",
        "runs.create",
        "runs.get",
        "runs.approve",
        "runs.stop",
        "jobs.list",
        "jobs.create",
        "jobs.get",
        "jobs.update",
        "jobs.delete",
        "jobs.pause",
        "jobs.resume",
        "jobs.run",
        "memory.snapshot",
        "memory.apply",
        "provider.catalog",
        "provider.validate",
        "provider.oauth.list",
        "provider.oauth.start",
        "provider.oauth.submit",
        "provider.oauth.poll",
        "provider.oauth.cancel",
        "model.info",
        "model.options",
        "model.auxiliary",
        "model.set",
        "model.moa.get",
        "model.moa.set",
        "toolsets.list",
        "toolsets.update",
        "toolsets.config",
        "toolsets.model",
        "toolsets.provider",
        "toolsets.post_setup",
        "skills.list",
        "skills.toggle",
        "skills.content",
        "skills.hub.sources",
        "skills.hub.search",
        "skills.hub.preview",
        "skills.hub.scan",
        "skills.hub.install",
        "skills.hub.update",
        "skills.hub.uninstall",
        "mcp.list",
        "mcp.catalog",
        "mcp.create",
        "mcp.update",
        "mcp.delete",
        "mcp.test",
        "mcp.auth",
        "mcp.enabled",
        "profiles.list",
        "profiles.active.get",
        "profiles.active.set",
        "profiles.create",
        "profiles.get",
        "profiles.update",
        "profiles.delete",
        "profiles.soul.get",
        "profiles.soul.set",
        "profiles.description.set",
        "profiles.model.set",
        "cron.history",
        "cron.delivery_targets",
        "cron.blueprints",
        "cron.blueprint.instantiate",
        "analytics.usage",
        "analytics.models",
        "diagnostics.status",
        "diagnostics.doctor",
        "diagnostics.security_audit",
        "diagnostics.checkpoints",
        "diagnostics.backup",
        "files.list",
        "files.read",
        "files.write",
        "files.upload",
        "files.mkdir",
        "files.delete"
      ]
    },
    "owner_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "user_id",
        "agent_id",
        "runtime_id",
        "workspace_id"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "runtime_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      },
      "dependentRequired": {
        "conversation_id": [
          "workspace_id"
        ]
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_id"
      ],
      "properties": {
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "roles": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          }
        }
      }
    },
    "channel_context": {
      "type": "object",
      "additionalProperties": true
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "parent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "span_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

