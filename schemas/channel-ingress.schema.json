{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/channel-ingress.schema.json",
  "title": "ChannelIngress",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner_scope",
    "ingress_id",
    "binding_id",
    "channel",
    "channel_account_id",
    "message_id",
    "sender",
    "conversation",
    "content",
    "received_at",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "owner_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "user_id",
        "agent_id",
        "workspace_id"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "runtime_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      },
      "dependentRequired": {
        "conversation_id": [
          "workspace_id"
        ]
      }
    },
    "ingress_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "binding_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "channel": {
      "enum": [
        "web",
        "cli",
        "feishu",
        "wechat",
        "qq"
      ]
    },
    "channel_account_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "message_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "sender": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_user_id"
      ],
      "properties": {
        "channel_user_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "display_name": {
          "type": "string",
          "maxLength": 200
        },
        "identity_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    },
    "conversation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_conversation_id",
        "kind"
      ],
      "properties": {
        "channel_conversation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "kind": {
          "enum": [
            "direct",
            "group",
            "thread"
          ]
        },
        "thread_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "title": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "text",
            "markdown",
            "image",
            "audio",
            "file",
            "event"
          ]
        },
        "text": {
          "type": "string",
          "maxLength": 100000
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "attachments": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "attachment_id",
          "kind"
        ],
        "properties": {
          "attachment_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
          },
          "kind": {
            "enum": [
              "image",
              "audio",
              "video",
              "file"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "maxLength": 4096
          },
          "media_type": {
            "type": "string",
            "maxLength": 200
          },
          "name": {
            "type": "string",
            "maxLength": 500
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "reply_to_message_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "parent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "span_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        }
      }
    }
  }
}
