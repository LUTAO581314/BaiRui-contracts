{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.bairui.ai/v2/lease-request-envelope.schema.json",
  "title": "LeaseRequestEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "organization_id",
    "user_id",
    "agent_id",
    "server_id",
    "request_id",
    "correlation_id",
    "idempotency_key",
    "created_at",
    "revision",
    "sequence",
    "signature",
    "limit",
    "lease_seconds",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "user_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "server_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value",
        "signed_at"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "ed25519",
            "hmac-sha256"
          ]
        },
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/=_-]{16,2048}$"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "lease_seconds": {
      "type": "integer",
      "minimum": 5,
      "maximum": 300
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "capability_refs": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:ref|id|hint):[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"
      }
    }
  }
}
